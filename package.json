function grade(percent){ if(percent>=90) return 'Grade 9 trajectory'; if(percent>=80) return 'Grade 8 trajectory'; if(percent>=70) return 'Grade 7 trajectory'; return 'Build towards Grade 7'; }
function csvEscape(value){ return `"${String(value).replaceAll('"','""')}"`; }

function readStoredArray(key){
  try {
    const value = localStorage.getItem(key);
    if(!value) return [];
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    localStorage.removeItem(key);
    return [];
  }
}

function readStoredTheme(){
  try {
    const saved = localStorage.getItem('aqaTheme');
    if(saved) return saved === 'dark';
  } catch {}
  return window.matchMedia?.('(prefers-color-scheme: dark)').matches ?? false;
}

export default function App(){
  const [page,setPage]=useState('home');
  const [dark,setDark]=useState(readStoredTheme);
  const [mode,setMode]=useState('Quick Quiz');
  const [topic,setTopic]=useState(topics[0]);
  const [questions,setQuestions]=useState([]);
  const [idx,setIdx]=useState(0);
  const [selected,setSelected]=useState(null);
  const [score,setScore]=useState(0);
  const [timeLeft,setTimeLeft]=useState(30);
  const [scores,setScores]=useState(()=>readStoredArray('aqaScores'));
  const [mistakes,setMistakes]=useState(()=>readStoredArray('aqaMistakes'));
  const [showModel,setShowModel]=useState(false);
  const xp=scores.reduce((sum,s)=>sum+s.score*10,0);

