const extraStems = [
  'Which answer best uses AQA Higher Tier reasoning?',
  'Which statement would gain the most credit in an exam answer?',
  'Which explanation avoids the most common misconception?',
  'Which conclusion is best supported by the chemistry?',
  'Which answer gives the clearest cause-and-effect link?'
];

function rotateOptions(row, shift){
  const [q, correct, opts, exp] = row;
  const arr = [...opts];
  const current = arr.indexOf(correct);
  const target = shift % 4;
  [arr[current], arr[target]] = [arr[target], arr[current]];
  return { question:q, answer:correct, options:arr, correctIndex:target, explanation:exp };
}

function buildBank(topicId){
  const seeds = topicSeeds[topicId];
  const out = [];
  for(let i=0;i<20;i++){
    const base = rotateOptions(seeds[i % seeds.length], i);
    const isExtended = i >= 12;
    out.push({
      id:`${topicId}-${i+1}`,
      topicId,
      category: topicId==='quantitative' || i%5===4 ? 'Calculation' : i%6===5 ? 'Required practical' : 'Multiple choice',
      difficulty: i<8?'Grade 7':i<15?'Grade 8':'Grade 9',
      question: `${base.question}${isExtended ? ' ' + extraStems[i % extraStems.length] : ''}`,
      options: base.options,
      correctIndex: base.correctIndex,
      explanation: base.explanation,
      commonMistake:'Giving a description without linking it to particles, bonding, energy, ions, moles or evidence.',
      examinerTip:'Use precise AQA command-word language: identify the idea, explain the reason, then link it to the result.',
      modelAnswer:`A Level 9 response would state that ${base.answer.toLowerCase()} and then justify it using accurate chemical reasoning, correct terminology and a clear link to the evidence in the question.`,
      markScheme:['1 mark for the correct chemical idea.','1 mark for accurate scientific terminology.','1 mark for explaining the cause, not just describing the observation.','1 mark for linking the explanation to the data, equation, practical method or particle model.']
    });
  }
  return out;
}

const questionBank = Object.fromEntries(topics.map(t => [t.id, buildBank(t.id)]));

