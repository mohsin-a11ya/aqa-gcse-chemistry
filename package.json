    document.documentElement.classList.toggle('dark', dark);
    try { localStorage.setItem('aqaTheme', dark ? 'dark' : 'light'); } catch {}
  },[dark]);
  React.useEffect(()=>{
    if(page!=='quiz' || selected!==null) return;
    if(timeLeft<=0){ choose(-1); return; }
    const t=setTimeout(()=>setTimeLeft(x=>x-1),1000);
    return ()=>clearTimeout(t);
  },[page,timeLeft,selected]);

  const current = questions[idx];
  const percent = questions.length ? Math.round((score/questions.length)*100) : 0;
  const topicStats = useMemo(()=>topics.map(t=>{const attempts=scores.filter(s=>s.topic===t.title); const avg=attempts.length?Math.round(attempts.reduce((a,b)=>a+b.percent,0)/attempts.length):0; return {...t, avg};}),[scores]);
  const weakest = topicStats.filter(t=>t.avg>0).sort((a,b)=>a.avg-b.avg)[0] || topics[0];

  function start(t, chosenMode=mode){
    const bank = [...questionBank[t.id]];
    let filtered = bank;
    if(chosenMode==='Calculations Only') filtered = bank.filter(q=>q.category==='Calculation');
    if(chosenMode==='Required Practicals') filtered = bank.filter(q=>q.category==='Required practical');
    if(filtered.length < 20) filtered = bank;
    const count = chosenMode==='Quick Quiz' ? 10 : 20;
    setTopic(t); setMode(chosenMode); setQuestions(filtered.slice(0,count)); setIdx(0); setScore(0); setSelected(null); setTimeLeft(30); setShowModel(false); setPage('quiz');
  }

  function choose(i){
    if(selected!==null) return;
    setSelected(i);
    const correct = i===current.correctIndex;
    if(correct) setScore(s=>s+1); else {
      const next=[current,...mistakes].slice(0,30);
      setMistakes(next); try { localStorage.setItem('aqaMistakes',JSON.stringify(next)); } catch {}
    }
  }
  function next(){ setSelected(null); setShowModel(false); setTimeLeft(30); setIdx(i=>i+1); }
  function finish(){ const entry={date:new Date().toLocaleString(),topic:topic.title,mode,score,questions:questions.length,percent,grade:grade(percent)}; const next=[entry,...scores].slice(0,50); setScores(next); try { localStorage.setItem('aqaScores',JSON.stringify(next)); } catch {} setPage('results'); }
  function exportCSV(){
    const rows=[['Date','Topic','Mode','Score','Questions','Percent','Grade'],...scores.map(s=>[s.date,s.topic,s.mode,s.score,s.questions,s.percent,s.grade])];
    const blob=new Blob([rows.map(r=>r.map(csvEscape).join(',')).join('\n')],{type:'text/csv'});
    const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download='aqa-chemistry-progress.csv'; a.click(); URL.revokeObjectURL(url);
  }

  const Shell=({children})=><div className="min-h-screen transition-colors duration-300 bg-[#FFF7F0] dark:bg-[#071827] text-[#112A46] dark:text-[#F8FAFC]"><header className="sticky top-0 z-10 backdrop-blur bg-white/90 dark:bg-[#071827]/95 border-b border-[#B20F57]/20 dark:border-[#33B8C9]/25"><div className="max-w-7xl mx-auto p-4 flex gap-3 items-center"><img src={logo} alt="Edspire logo" className="h-12 w-12 object-contain"/><div><h1 className="text-xl md:text-2xl font-black text-[#B20F57] dark:text-[#33B8C9]">AQA GCSE Chemistry Higher Tier</h1><p className="text-xs md:text-sm text-[#112A46]/75 dark:text-white/80">Paper 1 + Paper 2 • Grade 7-9 • 20 questions per topic</p></div><nav className="ml-auto hidden md:flex gap-2"><button onClick={()=>setPage('home')} className="nav"><Home size={16}/>Home</button><button onClick={()=>setPage('topics')} className="nav"><BookOpen size={16}/>Topics</button><button onClick={()=>setPage('practicals')} className="nav"><FlaskConical size={16}/>Practicals</button><button onClick={()=>setPage('calculations')} className="nav"><Calculator size={16}/>Calculations</button><button onClick={()=>setPage('dashboard')} className="nav"><BarChart3 size={16}/>Dashboard</button></nav><button onClick={()=>setDark(!dark)} aria-label={dark?'Switch to day mode':'Switch to night mode'} title={dark?'Switch to day mode':'Switch to night mode'} className="p-3 rounded-xl bg-[#33B8C9]/15 dark:bg-[#33B8C9]/25 text-[#B20F57] dark:text-[#F6B21A] border border-[#B20F57]/10 dark:border-[#33B8C9]/30 hover:scale-105 transition">{dark?<Sun/>:<Moon/>}</button></div></header>{children}</div>;

  if(page==='quiz' && current){
    const correct = selected===current.correctIndex;
    return <Shell><main className="max-w-4xl mx-auto p-5 py-8"><div className="flex gap-2 items-center mb-4"><span className="px-3 py-1 rounded-full bg-[#B20F57] text-white font-bold">{topic.paper}</span><span className="px-3 py-1 rounded-full bg-[#33B8C9]/20 font-bold">XP {xp}</span><span className="ml-auto font-black flex gap-2 items-center"><TimerReset/> {timeLeft}s</span></div><div className="h-3 rounded-full overflow-hidden bg-white mb-6"><div className="h-full bg-gradient-to-r from-[#B20F57] to-[#33B8C9]" style={{width:`${((idx+1)/questions.length)*100}%`}}/></div><section className="card"><p className="font-bold text-[#B20F57]">Question {idx+1} of {questions.length} • {current.category} • {current.difficulty}</p><h2 className="text-2xl font-black mt-4">{current.question}</h2><div className="grid gap-3 mt-6">{current.options.map((op,i)=><button key={op+i} onClick={()=>choose(i)} className={`text-left p-4 rounded-2xl border-2 font-semibold transition ${selected===null?'hover:scale-[1.01] hover:border-[#33B8C9]':'opacity-95'} ${selected!==null&&i===current.correctIndex?'border-emerald-500 bg-emerald-50 text-emerald-900':''} ${selected===i&&i!==current.correctIndex?'border-red-500 bg-red-50 text-red-900':''}`}>{letters[i]}. {op}</button>)}</div>{selected!==null&&<div className="mt-6 p-5 rounded-2xl bg-[#FFF7F0] dark:bg-[#0b1b2e]"><h3 className="font-black text-xl">{correct?'Correct.':selected===-1?'Timed out.':'Not quite.'}</h3><p className="mt-2">{current.explanation}</p><p className="mt-2 text-[#B20F57]"><b>Common mistake:</b> {current.commonMistake}</p><p className="mt-2"><b>Examiner tip:</b> {current.examinerTip}</p><button onClick={()=>setShowModel(!showModel)} className="mt-4 px-4 py-2 rounded-xl bg-[#B20F57] text-white font-bold">Show model answer and mark scheme</button>{showModel&&<div className="mt-4 p-4 rounded-xl bg-white dark:bg-[#0b1b2e]"><p className="font-bold">Level 9 model answer</p><p>{current.modelAnswer}</p><p className="font-bold mt-4">Detailed AQA mark scheme</p><ul className="list-disc pl-6">{current.markScheme.map(m=><li key={m}>{m}</li>)}</ul></div>}</div>}<div className="mt-6 flex justify-between"><button onClick={()=>setPage('topics')} className="px-4 py-2 rounded-xl bg-slate-200 font-bold text-[#112A46]">Exit</button>{selected!==null&&(idx<questions.length-1?<button onClick={next} className="primary">Next</button>:<button onClick={finish} className="primary">Finish</button>)}</div></section></main></Shell>;
  }

  if(page==='results') return <Shell><main className="max-w-4xl mx-auto p-6 text-center"><Trophy className="mx-auto text-[#F6B21A]" size={72}/><h2 className="text-4xl font-black mt-4">{grade(percent)}</h2><p className="text-xl mt-2">You scored {score}/{questions.length} ({percent}%).</p><p className="mt-3">AQA examiner report: {percent>=80?'Strong Grade 8-9 reasoning. Keep linking observations to particle, bonding and quantitative ideas.':'Use the mark schemes to add precise chemical reasoning, not just descriptions.'}</p><div className="mt-8 flex justify-center gap-3"><button onClick={()=>start(topic,mode)} className="primary">Retry</button><button onClick={()=>setPage('dashboard')} className="secondary">Dashboard</button></div></main></Shell>;

  return <Shell><main className="max-w-7xl mx-auto p-5 py-8">{page==='home'&&<><section className="rounded-[2rem] p-8 md:p-12 bg-gradient-to-br from-[#B20F57] via-[#112A46] to-[#33B8C9] text-white shadow-2xl"><p className="font-black uppercase tracking-widest">Edspire-colour AQA revision platform</p><h2 className="text-4xl md:text-6xl font-black mt-3">AQA Chemistry Higher revision that feels like a game.</h2><p className="mt-5 max-w-3xl text-lg text-white/90">20 questions per topic, 30-second timers, Level 9 mark schemes, AQA command-word practice, calculations, required practicals without images, XP, badges and examiner feedback.</p><div className="mt-6 flex flex-wrap gap-3"><button onClick={()=>start(topics[0],'Quick Quiz')} className="px-6 py-3 rounded-2xl bg-white text-[#B20F57] font-black">Start Quick Quiz</button><button onClick={()=>setPage('topics')} className="px-6 py-3 rounded-2xl bg-white/15 border border-white/40 font-black">Choose Topic</button></div></section><section className="grid md:grid-cols-4 gap-4 mt-6">{[['Daily challenge','Complete one Paper 1 and one Paper 2 quiz',Sparkles],['Boss battles','Grade 9 stems appear in longer sets',Zap],['Adaptive revision',`Target area: ${weakest.title}`,Target],['Trajectory',scores[0]?.grade||'No attempts yet',GraduationCap]].map(([h,p,I])=><div key={h} className="card"><I className="text-[#B20F57]"/><h3 className="font-black mt-3">{h}</h3><p className="text-sm mt-1">{p}</p></div>)}</section></>}{page==='topics'&&<><h2 className="text-3xl font-black mb-5">AQA specification topics</h2><div className="flex flex-wrap gap-2 mb-6">{['Quick Quiz','Exam Mode','Grade 9 Challenge','Required Practicals','Calculations Only'].map(m=><button key={m} onClick={()=>setMode(m)} className={`px-4 py-2 rounded-xl font-bold ${mode===m?'bg-[#B20F57] text-white':'bg-white dark:bg-[#0b1b2e] text-[#112A46] dark:text-white border border-[#B20F57]/20'}`}>{m}</button>)}</div><div className="grid md:grid-cols-2 lg:grid-cols-3 gap-5">{topics.map(t=><div key={t.id} className="card overflow-hidden p-0"><div className="h-3 bg-gradient-to-r from-[#B20F57] to-[#33B8C9]"/><div className="p-5"><p className="font-bold text-[#B20F57]">{t.paper}</p><h3 className="text-xl font-black mt-1">{t.title}</h3><p className="text-sm mt-2">{t.desc}</p><p className="text-xs mt-3 font-bold text-[#33B8C9]">20 questions available</p><button onClick={()=>start(t,mode)} className="mt-5 w-full py-3 rounded-xl bg-[#112A46] dark:bg-[#33B8C9] text-white dark:text-[#112A46] font-black">Start {mode}</button></div></div>)}</div></>}{page==='practicals'&&<><h2 className="text-3xl font-black mb-5">AQA required practicals</h2><p className="mb-5">Images have been removed. This section is now cleaner and focused on method, variables, accuracy and examiner tips.</p><div className="grid md:grid-cols-2 gap-5">{practicals.map(([paper,title,method,tip])=><div key={title} className="card"><p className="text-[#B20F57] font-bold">{paper}</p><h3 className="text-xl font-black">{title}</h3><p className="mt-3"><b>Method:</b> {method}</p><p className="mt-2 text-[#B20F57]"><b>Level 9 tip:</b> {tip}</p><button onClick={()=>start(topics.find(t=>t.paper===paper) || topics[0],'Required Practicals')} className="mt-4 primary">Practise questions</button></div>)}</div></>}{page==='calculations'&&<><h2 className="text-3xl font-black mb-5">AQA Higher calculation practice</h2><div className="grid md:grid-cols-2 gap-4">{calculations.map(([title,formula,example])=><div key={title} className="card"><Calculator className="text-[#B20F57]"/><h3 className="font-black text-xl mt-2">{title}</h3><p className="font-mono mt-2 bg-[#FFF7F0] dark:bg-[#0b1b2e] p-3 rounded-xl">{formula}</p><p className="mt-2 text-sm">Example: {example}</p></div>)}</div></>}{page==='dashboard'&&<><h2 className="text-3xl font-black mb-5">Progress dashboard</h2><div className="grid md:grid-cols-4 gap-4 mb-6"><div className="card"><p className="text-sm">Total XP</p><h3 className="text-3xl font-black">{xp}</h3></div><div className="card"><p className="text-sm">Attempts</p><h3 className="text-3xl font-black">{scores.length}</h3></div><div className="card"><p className="text-sm">Target area</p><h3 className="font-black">{weakest.title}</h3></div><div className="card"><p className="text-sm">Saved mistakes</p><h3 className="text-3xl font-black">{mistakes.length}</h3></div></div><button onClick={exportCSV} className="primary flex gap-2 items-center"><Download size={16}/> Export CSV</button><div className="grid md:grid-cols-2 gap-5 mt-6"><div className="card"><h3 className="font-black mb-3">Recent attempts</h3>{scores.length?scores.slice(0,8).map(s=><div key={s.date+s.topic+s.percent} className="py-2 border-b"><b>{s.grade}</b> — {s.topic} ({s.percent}%)</div>):<p>No attempts yet.</p>}</div><div className="card"><h3 className="font-black mb-3">Spaced repetition mistakes</h3>{mistakes.length?mistakes.slice(0,8).map(m=><div key={m.id} className="py-2 border-b"><b>{topics.find(t=>t.id===m.topicId)?.title}</b><p className="text-sm">{m.question}</p></div>):<p>No mistakes saved yet.</p>}</div></div></>}<section className="mt-8 card"><h3 className="font-black flex gap-2 items-center"><ClipboardList/> AQA command words</h3><div className="grid md:grid-cols-3 gap-3 mt-3">{[['Calculate','Use numbers and show working.'],['Explain','Give reasons using chemical ideas.'],['Evaluate','Use evidence to make a judgement.'],['Compare','Give similarities and differences.'],['Suggest','Apply knowledge to an unfamiliar context.'],['Describe','Say what happens or what is seen.']].map(([w,d])=><p key={w} className="p-3 rounded-xl bg-[#FFF7F0] dark:bg-[#0b1b2e]"><b>{w}:</b> {d}</p>)}</div></section></main></Shell>;
}
